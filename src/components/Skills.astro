---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { SiPython, SiJavascript, SiReact, SiNodedotjs, SiNestjs, SiFastapi, SiMongodb, SiN8N, SiDocker, SiNextdotjs, SiPostgresql, SiTailwindcss, SiVite, SiHtml5 } from 'react-icons/si';
import { FaJava, FaDatabase, FaCss3 } from 'react-icons/fa';
import projectsData from '../../public/projects.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const baseSkills = [
  { name: 'Python', icon: SiPython, color: "#3776AB" },
  { name: 'JavaScript', icon: SiJavascript, color: "#F7DF1E" },
  { name: 'React', icon: SiReact, color: "#61DAFB" },
  { name: 'Node.js', icon: SiNodedotjs, color: "#339933" },
  { name: 'NestJS', icon: SiNestjs, color: "#E0234E" },
  { name: 'FastAPI', icon: SiFastapi, color: "#009688" },
  { name: 'Java', icon: FaJava, color: "#ED8B00" },
  { name: 'MongoDB', icon: SiMongodb, color: "#47A248" },
  { name: 'SQL', icon: FaDatabase, color: "#0078D4" },
  { name: 'N8N', icon: SiN8N, color: "#EA4B71" },
];

const tagToSkillMap = {
  docker: { name: 'Docker', icon: SiDocker, color: "#2496ED" },
  'next.js': { name: 'Next.js', icon: SiNextdotjs, color: "#000000" },
  postgresql: { name: 'PostgreSQL', icon: SiPostgresql, color: "#336791" },
  tailwind: { name: 'Tailwind CSS', icon: SiTailwindcss, color: "#06B6D4" },
  vite: { name: 'Vite', icon: SiVite, color: "#646CFF" },
  html5: { name: 'HTML5', icon: SiHtml5, color: "#E34F26" },
  css3: { name: 'CSS3', icon: FaCss3, color: "#1572B6" },
};

const usedTags = new Set(
  projectsData.flatMap((project) => project.tags.map((tag) => tag.toLowerCase()))
);

const existingSkillNames = new Set(baseSkills.map((skill) => skill.name.toLowerCase()));

const additionalSkills = Object.entries(tagToSkillMap)
  .filter(([tag, skill]) => usedTags.has(tag) && !existingSkillNames.has(skill.name.toLowerCase()))
  .map(([, skill]) => skill);

const skills = [...baseSkills, ...additionalSkills];
---

<section id="skills" class="py-24 bg-foreground/[0.02] dark:bg-dark-foreground/[0.02]" aria-labelledby="skills-heading">
  <div class="container mx-auto px-6">
    <div class="animate-on-scroll opacity-0 translate-y-8 transition-all duration-700">
      <h2 id="skills-heading" class="text-3xl md:text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent dark:from-dark-primary dark:to-dark-accent mb-4 text-center">{t('skills_title')}</h2>
      <p class="text-lg text-foreground/60 dark:text-dark-foreground/60 max-w-2xl mx-auto text-center mb-16">{t('skills_subtitle')}</p>
      
      <div 
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6 max-w-5xl mx-auto"
      >
        {skills.map((skill, index) => {
          const Icon = skill.icon;
          return (
          <div
            class="skill-card card-glass flex flex-col items-center justify-center p-6 group cursor-pointer opacity-0 translate-y-4 transition-all duration-500"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="group-hover:scale-110 transition-transform duration-300">
               <Icon className="h-12 w-12" style={{color: skill.color}} />
            </div>
            <p class="mt-4 font-semibold text-sm text-card-foreground dark:text-dark-card-foreground">{skill.name}</p>
          </div>
        )})}
      </div>
    </div>
  </div>
</section>

<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.remove('opacity-0', 'translate-y-8');
                
                // Animate children skills
                const skills = entry.target.querySelectorAll('.skill-card');
                skills.forEach(skill => {
                    skill.classList.remove('opacity-0', 'translate-y-4');
                });
                
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.2 });

    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
